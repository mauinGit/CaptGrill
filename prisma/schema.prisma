generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255)
  name      String   @db.VarChar(100)
  role      Role     @default(KASIR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions   Transaction[]
  attendances    Attendance[]
  salaries       Salary[]
  logs           Log[]
  productionLogs ProductionLog[]

  @@map("users")
}

enum Role {
  ADMIN
  KASIR
}

model Menu {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  price       Int
  image       String?  @db.Text
  isAvailable Boolean  @default(true)
  category    String   @default("Makanan") @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menuIngredients    MenuIngredient[]
  transactionDetails TransactionDetail[]

  @@map("menus")
}

model Ingredient {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  unit      String   @db.VarChar(20)
  stock     Decimal    @default(0)
  minStock  Decimal    @default(0)
  category  String?  @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menuIngredients    MenuIngredient[]
  recipeCompositions RecipeComposition[]
  recipes            Recipe[]

  @@map("ingredients")
}

model MenuIngredient {
  id           Int   @id @default(autoincrement())
  menuId       Int
  ingredientId Int
  quantity     Decimal

  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([menuId, ingredientId])
  @@map("menu_ingredients")
}

model Transaction {
  id            Int               @id @default(autoincrement())
  orderNumber   String?           @unique @db.VarChar(30)
  userId        Int
  totalPrice    Int
  discount      Int               @default(0)
  finalPrice    Int
  amountPaid    Int               @default(0)
  paymentMethod String            @default("Cash") @db.VarChar(30)
  status        TransactionStatus @default(COMPLETED)
  createdAt     DateTime          @default(now())

  user    User                @relation(fields: [userId], references: [id])
  details TransactionDetail[]

  @@map("transactions")
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model TransactionDetail {
  id            Int @id @default(autoincrement())
  transactionId Int
  menuId        Int
  quantity      Int
  subtotal      Int

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  menu        Menu        @relation(fields: [menuId], references: [id])

  @@map("transaction_details")
}

model Expense {
  id          Int      @id @default(autoincrement())
  category    String   @db.VarChar(50)
  description String   @db.VarChar(255)
  amount      Int
  date        DateTime @db.Date
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}

model Attendance {
  id        Int      @id @default(autoincrement())
  userId    Int
  photo     String?  @db.Text
  latitude  Decimal?
  longitude Decimal?
  purpose   String?  @default("Shift 1") @db.VarChar(30)
  date      DateTime @db.Date
  clockIn   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date, purpose])
  @@map("attendance")
}

model Salary {
  id            Int      @id @default(autoincrement())
  userId        Int
  period        String   @db.VarChar(20)
  totalDays     Int
  dailyRate     Int
  totalSalary   Int
  shiftDays     Int      @default(0)
  shiftRate     Int      @default(0)
  gajiShift     Int      @default(0)
  produksiDays  Int      @default(0)
  produksiRate  Int      @default(0)
  gajiProduksi  Int      @default(0)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("salary")
}

model Log {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String   @db.VarChar(50)
  detail    String   @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("logs")
}

model Recipe {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  ingredientId Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingredient     Ingredient          @relation(fields: [ingredientId], references: [id])
  compositions   RecipeComposition[]
  productionLogs ProductionLog[]

  @@map("recipes")
}

model RecipeComposition {
  id           Int   @id @default(autoincrement())
  recipeId     Int
  ingredientId Int
  quantity     Decimal

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@map("recipe_compositions")
}

model ProductionLog {
  id           Int      @id @default(autoincrement())
  recipeId     Int
  userId       Int
  quantity     Int
  detail       String   @db.Text
  createdAt    DateTime @default(now())

  recipe Recipe @relation(fields: [recipeId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("production_logs")
}
